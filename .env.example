# Copy this file to .env and fill in real values. Never commit .env.
# All variables here can override the corresponding config/<NETWORK>.toml values.

# Target network: local | testnet | staging | mainnet (default: local)
NETWORK=local

# RPC endpoint — overrides network.rpc_url in the TOML config
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — overrides network.network_passphrase in the TOML config
# STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployer secret key (required for deployment, never commit)
STELLAR_SECRET_KEY=

# Deployed contract addresses — override contracts.* in the TOML config
# GOVERNANCE_CONTRACT_ID=
# TOKEN_CONTRACT_ID=
