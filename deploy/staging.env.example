# =============================================================================
# VoteChain — Staging Environment
# =============================================================================
# Copy to deploy/staging.env and fill in the real values.
#
#   cp deploy/staging.env.example deploy/staging.env
#
# deploy/staging.env must NEVER be committed to the repository.
# In CI/CD, populate these values from your secret store (e.g. GitHub Secrets).
# =============================================================================

# Network — staging runs against Stellar Testnet
NETWORK=staging
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployer keypair
# In CI: set via $STAGING_STELLAR_SECRET_KEY / $STAGING_STELLAR_PUBLIC_KEY secrets
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Contract addresses (populated by scripts/deploy.sh after staging deployment)
GOVERNANCE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TOKEN_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Governance parameters
MIN_PROPOSAL_BALANCE=1000000
PROPOSAL_COOLDOWN=3600

# Backend
PORT=3001

# Database (indexer)
DATABASE_URL=postgres://votechain:changeme@db:5432/votechain_staging

# Redis cache
REDIS_URL=redis://redis:6379
