# =============================================================================
# VoteChain — Mainnet Environment
# =============================================================================
# NEVER commit real values to this file or any derived .env file.
# All secrets below must be injected at deploy time from a secrets manager
# (e.g. AWS Secrets Manager, HashiCorp Vault, GitHub Secrets).
#
# Recommended flow:
#   1. Store secrets in your secrets manager.
#   2. During deployment, export the variables into the shell environment.
#   3. Pass them to the deployment script: NETWORK=mainnet ./scripts/deploy.sh
#
# Secret variables are marked with "SECRET — inject at runtime".
# =============================================================================

# Network
NETWORK=mainnet
STELLAR_RPC_URL=https://soroban-mainnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# Deployer keypair — SECRET — inject at runtime
# Source: secrets manager key  mainnet/STELLAR_SECRET_KEY
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Contract addresses (populated after mainnet deployment; store in secrets manager)
# Source: secrets manager key  mainnet/GOVERNANCE_CONTRACT_ID
GOVERNANCE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Source: secrets manager key  mainnet/TOKEN_CONTRACT_ID
TOKEN_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Governance parameters (review carefully before mainnet deployment)
MIN_PROPOSAL_BALANCE=1000000
PROPOSAL_COOLDOWN=86400

# Backend
PORT=3001

# Database — SECRET — inject at runtime
# Source: secrets manager key  mainnet/DATABASE_URL
DATABASE_URL=postgres://votechain:CHANGEME@db:5432/votechain_mainnet

# Redis — SECRET — inject at runtime
# Source: secrets manager key  mainnet/REDIS_URL
REDIS_URL=redis://:CHANGEME@redis:6379
