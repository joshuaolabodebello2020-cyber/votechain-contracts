{
  "dashboard": {
    "title": "VoteChain Service Health",
    "uid": "votechain-service-health",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Status Overview",
        "type": "stat",
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "up{job=~\"backend|indexer|stellar-rpc|stellar-rpc-http\"}",
            "legendFormat": "{{ job }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Backend - Uptime",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "up{job=\"backend\"}",
            "legendFormat": "backend"
          }
        ]
      },
      {
        "id": 3,
        "title": "Stellar RPC - Uptime",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
        "targets": [
          {
            "expr": "up{job=~\"stellar-rpc|stellar-rpc-http\"}",
            "legendFormat": "{{ job }}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Indexer - Uptime",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
        "targets": [
          {
            "expr": "up{job=\"indexer\"}",
            "legendFormat": "indexer"
          }
        ]
      },
      {
        "id": 5,
        "title": "Backend - Response Time (scrape duration)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "scrape_duration_seconds{job=\"backend\"}",
            "legendFormat": "backend scrape"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 6,
        "title": "Stellar RPC - Response Time (scrape duration)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "scrape_duration_seconds{job=~\"stellar-rpc|stellar-rpc-http\"}",
            "legendFormat": "{{ job }}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 7,
        "title": "Service Availability (30m window)",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "avg_over_time(up{job=~\"backend|indexer|stellar-rpc|stellar-rpc-http\"}[30m]) * 100",
            "legendFormat": "{{ job }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 90, "color": "yellow" },
                { "value": 99, "color": "green" }
              ]
            }
          }
        }
      }
    ]
  }
}
